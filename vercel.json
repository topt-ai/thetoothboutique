{
  "trailingSlash": false,
  "redirects": [
    {
      "source": "https://www.thetoothboutique.com/(.*)",
      "destination": "https://thetoothboutique.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)/",
      "destination": "/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/invisalign",
      "destination": "/invisalign.html"
    },
    {
      "source": "/brackets",
      "destination": "/brackets.html"
    },
    {
      "source": "/blanqueamiento",
      "destination": "/blanqueamiento.html"
    },
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    },
    {
      "source": "/(.*\\.webp|.*\\.png|.*\\.jpg|.*\\.svg)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
